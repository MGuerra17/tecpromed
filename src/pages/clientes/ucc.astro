---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import data from "../../data/ucc-versions.json";

const latestVersion = data.versions[0];
---

<BaseLayout
  title={`Portal de Descargas - ${data.client} | Tecpromed`}
  description={`Descargas del Facturador para ${data.client}.`}
  canonicalPath="clientes/ucc"
>
  <Header />
  <main class="min-h-screen bg-slate-50 py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      <header class="mb-12 text-center pt-8">
        <h1 class="text-3xl md:text-5xl font-bold text-slate-800 mb-4">
          {data.client}
        </h1>
        <p class="text-slate-600 text-lg">
          Portal seguro de descarga de actualizaciones.
        </p>
      </header>

      <!-- Botón Principal -->
      <section
        class="bg-white border text-center border-slate-200 rounded-2xl p-8 mb-12 shadow-sm relative overflow-hidden"
      >
        <div
          class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-primary to-indigo-600"
        >
        </div>
        <h2 class="text-2xl font-bold text-slate-800 mb-2">
          Última Versión (v{latestVersion.version})
        </h2>
        <p
          class="text-slate-500 mb-6 font-mono text-sm bg-slate-100 inline-block px-3 py-1 rounded-full border border-slate-200"
        >
          Publicada: {latestVersion.date}
        </p>

        <!-- Contenedor del boton con estilos modernos -->
        <div>
          <a
            href={latestVersion.fileUrl}
            download
            class="inline-block bg-primary hover:bg-primary/90 text-white font-bold py-4 px-10 rounded-xl text-lg transition-all duration-300 hover:scale-105 hover:shadow-lg shadow-md shadow-blue-600/30"
          >
            <span class="mr-2">📥</span> Descargar Instalador
          </a>
        </div>
        <p
          class="mt-6 text-sm font-medium text-amber-800 bg-amber-50 inline-block px-4 py-2 rounded-lg border border-amber-200"
        >
          ⚠️ El archivo está protegido con la contraseña proporcionada de forma
          privada.
        </p>
      </section>

      <!-- Historial -->
      <section>
        <h3
          class="text-xl font-bold text-slate-800 mb-6 border-b border-slate-200 pb-3"
        >
          Historial de Actualizaciones
        </h3>
        <div class="space-y-4">
          {
            data.versions.map((v) => (
              <div class="border border-slate-200 rounded-xl p-5 flex flex-col md:flex-row justify-between items-start md:items-center bg-white hover:border-primary transition-colors shadow-sm hover:shadow">
                <div class="mb-4 md:mb-0">
                  <div class="flex items-center gap-3 mb-2">
                    <h4 class="font-bold text-lg text-slate-800">
                      v{v.version}
                    </h4>
                    <span class="text-xs text-slate-600 font-mono bg-slate-100 px-2 py-1 rounded border border-slate-200">
                      {v.date}
                    </span>
                  </div>
                  <ul class="list-disc list-inside text-sm text-slate-600 space-y-1">
                    {v.changelog.map((change) => (
                      <li>{change}</li>
                    ))}
                  </ul>
                </div>

                <a
                  href={v.fileUrl}
                  download
                  class="inline-block px-5 py-2.5 border-2 border-slate-200 rounded-lg text-slate-700 hover:bg-slate-50 hover:text-primary font-semibold transition-all text-sm whitespace-nowrap"
                >
                  Descargar v{v.version}
                </a>
              </div>
            ))
          }
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
